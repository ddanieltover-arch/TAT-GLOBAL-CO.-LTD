// TAT GLOBAL CO., LTD — lead storage for admin dashboard (PostgreSQL via Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum SubmissionStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model QuoteRequest {
  id                  String           @id @default(cuid())
  fullName            String
  companyName         String
  email               String
  phone               String
  whatsapp            String
  country             String
  productInterested   String
  quantityRequired    String
  packagingPreference String
  deliveryDestination String
  message             String           @db.Text
  preferredContact    String?
  purchaseTimeline    String?
  gdprConsent         Boolean          @default(true)
  locale              String?
  fileAttachmentName  String?
  fileAttachmentType  String?
  fileAttachmentSize  Int?
  status              SubmissionStatus @default(NEW)
  ipAddress           String?
  userAgent           String?
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("quote_requests")
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model ContactSubmission {
  id          String           @id @default(cuid())
  fullName    String
  companyName String
  email       String
  message     String           @db.Text
  gdprConsent Boolean          @default(true)
  locale      String?
  status      SubmissionStatus @default(NEW)
  ipAddress   String?
  userAgent   String?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("contact_submissions")
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String?
  gdprConsent Boolean @default(true)
  isActive  Boolean  @default(true)
  source    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
  @@index([isActive])
  @@index([createdAt])
}
