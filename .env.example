# =============================================================================
# TAT GLOBAL CO., LTD — environment template
# =============================================================================
# Local:  cp .env.example .env.local   then fill secrets below
# Check:  npm run check:env
# Docs:   docs/ENVIRONMENT.md
#
# PRODUCTION (must set on host + rebuild for NEXT_PUBLIC_*):
#   RESEND_API_KEY          → live quote/contact/newsletter email
#   QUOTE_FROM_EMAIL        → verified sender in Resend
#   NEXT_PUBLIC_WHATSAPP_PHONE → WhatsApp button + contact (build time)
#   NEXT_PUBLIC_SITE_URL    → canonical / sitemap / OG (build time)
# =============================================================================

# --- Public (embedded at `npm run build`) ------------------------------------

NEXT_PUBLIC_SITE_URL=https://tatglcoltd.com

# Export sales WhatsApp: +66 82 960 0612 (digits with or without +)
NEXT_PUBLIC_WHATSAPP_PHONE=+66829600612

# --- Email via Resend (required for live forms) ------------------------------

# https://resend.com/api-keys
RESEND_API_KEY=

# Must use a domain verified in Resend
QUOTE_FROM_EMAIL=TAT Global <notifications@tatglcoltd.com>

# Inboxes receiving quote + contact notifications
QUOTE_TO_EMAIL=sales@tatglcoltd.com
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Newsletter (defaults to QUOTE_* when blank)
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_TO_EMAIL=

# --- CRM webhook (optional) --------------------------------------------------

# CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy/
# CRM_QUOTE_WEBHOOK_URL=
# CRM_CONTACT_WEBHOOK_URL=
# CRM_WEBHOOK_SECRET=

# --- SMTP fallback (local dev only — not for production) -----------------------

# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# --- Rate limits (optional) --------------------------------------------------

# QUOTE_RATE_LIMIT_MAX=5
# QUOTE_RATE_LIMIT_WINDOW_MS=900000
# CONTACT_RATE_LIMIT_MAX=5
# CONTACT_RATE_LIMIT_WINDOW_MS=900000
# NEWSLETTER_RATE_LIMIT_MAX=10
# NEWSLETTER_RATE_LIMIT_WINDOW_MS=3600000
